# =============================================================
# SAKHY — Environment Variables
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local — it is already in .gitignore.
# =============================================================

# ── DATABASE ─────────────────────────────────────────────────
# Local dev (Docker Postgres):
DATABASE_URL="postgresql://sakhy:sakhy_dev_password@localhost:5432/sakhy_db?schema=public"
# Staging/prod (Supabase connection pooler — Transaction mode, port 6543):
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection for migrations (Supabase, port 5432):
# DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── AUTH (NextAuth / Auth.js) ─────────────────────────────────
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
CRON_SECRET="generate-with-openssl-rand-base64-32"

# ── SUPABASE (staging/prod — server-side only) ────────────────
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# ⚠ NEVER expose service role key to the browser
SUPABASE_SERVICE_ROLE_KEY=""

# ── RAZORPAY ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
# This is the only Razorpay key that goes to the browser:
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# ── EMAIL ────────────────────────────────────────────────────
RESEND_API_KEY=""

# ── MONITORING ───────────────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ── RATE LIMITING ────────────────────────────────────────────
# Phase 3 uses a durable Postgres-backed limiter via Prisma.
# Upstash Redis can replace this later if traffic/latency justifies it.

# ── IMAGE STORAGE ─────────────────────────────────────────────
# Supabase Storage bucket name for product images
SUPABASE_STORAGE_BUCKET="product-images"
